{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "createdAt"]
    },
    "SubCategory": {
      "title": "SubCategory",
      "description": "Product subcategory",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["categoryId", "name", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user in the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User email address." },
        "createdAt": { "type": "string", "description": "Creation timestamp." },
        "role": { "type": "string", "enum": ["customer", "admin"], "description": "User role." }
      },
      "required": ["email", "createdAt", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "An e-commerce product.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Product title" },
        "description": { "type": "string", "description": "Product details" },
        "originalPrice": { "type": "number", "description": "Original price of the product" },
        "price": { "type": "number", "description": "Price of the product" },
        "category": { "type": "string", "description": "Category name or ID" },
        "subCategory": { "type": "string", "description": "Subcategory name or ID" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs or base64" },
        "inventory": { "type": "number", "description": "Number of items in stock" },
        "rating": { "type": "number", "description": "Average rating" },
        "reviewCount": { "type": "number", "description": "Number of reviews" },
        "createdAt": { "type": "string", "description": "Creation timestamp." },
        "updatedAt": { "type": "string", "description": "Last update timestamp." }
      },
      "required": ["title", "description", "price", "category", "images", "inventory", "createdAt", "updatedAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a product.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who reviewed" },
        "userName": { "type": "string", "description": "Name or email of the user" },
        "rating": { "type": "number", "description": "Rating out of 5" },
        "text": { "type": "string", "description": "Review text" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs" },
        "createdAt": { "type": "string", "description": "Creation timestamp." }
      },
      "required": ["userId", "rating", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed order" },
        "items": { "type": "array", "items": { "$ref": "#/entities/OrderItem" }, "description": "Items in the order" },
        "totalAmount": { "type": "number", "description": "Total checkout amount" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"], "description": "Order status" },
        "paymentMethod": { "type": "string", "enum": ["razorpay", "cod"] },
        "paymentId": { "type": "string", "description": "Razorpay payment/order ID" },
        "address": { "type": "object", "properties": {
            "name": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zip": { "type": "string" },
            "contactNumber": { "type": "string" }
        } },
        "createdAt": { "type": "string", "description": "Creation timestamp." },
        "updatedAt": { "type": "string", "description": "Last update timestamp." }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt", "updatedAt"]
    },
    "OrderItem": {
       "title": "OrderItem",
       "description": "Item within an order",
       "type": "object",
       "properties": {
         "productId": { "type": "string" },
         "quantity": { "type": "number" },
         "priceAtPurchase": { "type": "number" }
       },
       "required": ["productId", "quantity", "priceAtPurchase"]
    },
    "Wishlist": {
       "title": "Wishlist",
       "description": "Items wishlisted by a user",
       "type": "object",
       "properties": {
         "productIds": { "type": "array", "items": { "type": "string" }, "description": "Array of product ids" },
         "updatedAt": { "type": "string", "description": "Last update timestamp." }
       },
       "required": ["productIds", "updatedAt"]
    },
    "AdminSettings": {
      "title": "AdminSettings",
      "description": "Global admin configuration.",
      "type": "object",
      "properties": {
        "razorpayMerchantId": { "type": "string", "description": "Razorpay Key ID" },
        "razorpayMerchantSecret": { "type": "string", "description": "Razorpay Key Secret" }
      },
      "required": []
    }
  },
  "firestore": {
    "categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories"
    },
    "subcategories/{subcategoryId}": {
      "schema": { "$ref": "#/entities/SubCategory" },
      "description": "Product subcategories"
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles"
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products catalog"
    },
    "products/{productId}/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Product reviews"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "All orders"
    },
    "wishlists/{userId}": {
      "schema": { "$ref": "#/entities/Wishlist" },
      "description": "User wishlists"
    },
    "settings/admin": {
      "schema": { "$ref": "#/entities/AdminSettings" },
      "description": "Global admin settings"
    }
  }
}
